@article{shahImagingTechniquesDetection2014,
  title = {Imaging Techniques for the Detection of Stored Product Pests},
  author = {Shah, Mohd Abas and Khan, Akhtar Ali},
  date = {2014-05-01},
  journaltitle = {Applied Entomology and Zoology},
  shortjournal = {Appl Entomol Zool},
  volume = {49},
  number = {2},
  pages = {201--212},
  issn = {1347-605X},
  doi = {10.1007/s13355-014-0254-2},
  url = {https://doi.org/10.1007/s13355-014-0254-2},
  urldate = {2023-10-16},
  abstract = {Stored grains are subject to deterioration and losses through various factors, but mainly insects and fungi. Various techniques are employed to detect stored product pests; however, there is an urgent need for an industrial-scale on-line detection technique. Near-infrared hyperspectroscopic imaging and soft X-rays have shown the potential for real-time application. These techniques are particularly effective for detecting internal infestations of stored grains. The digital images of the scanned objects are analyzed for various spectral and image features using statistical techniques such as complex multivariate tools. Classification accuracies as high as 80–100~\% have been achieved for various pest and grain combinations. Dual-energy X-rays have been shown to detect the concealed eggs of stored product insect pests. The main threats to stored cereals come from Aspergillus spp., Penicillium spp., and Fusarium spp., which may produce mycotoxins. These imaging techniques have shown good results in the detection of fungal infections of stored grain.},
  langid = {english},
  keywords = {Hyperspectroscopy,Internal infestation,Mycotoxins,Sitophilus oryzae,Soft X-rays},
  file = {C:\Users\dank\Zotero\storage\INBVWZJT\Shah and Khan - 2014 - Imaging techniques for the detection of stored product pests.pdf}
}

@article{shayestehMortalityBehaviourTwo1996,
  title = {Mortality and Behaviour of Two Stored-Product Insect Species during Microwave Irradiation},
  author = {Shayesteh, N. and Barthakur, N. N.},
  date = {1996-07-01},
  journaltitle = {Journal of Stored Products Research},
  shortjournal = {Journal of Stored Products Research},
  volume = {32},
  number = {3},
  pages = {239--246},
  issn = {0022-474X},
  doi = {10.1016/S0022-474X(96)00016-1},
  url = {https://www.sciencedirect.com/science/article/pii/S0022474X96000161},
  urldate = {2026-03-25},
  abstract = {Mortality of the stored-product insects Tribolium confusum and Plodia interpunctella exposed, either intermittently or continuously, to microwave radiation (2450 MHz) was evaluated as a function of exposure time and power, as well as at different growth stages. The survival kinetic was highly quadratic (0.82 ≤ R2 ≤ 0.99) for each of the growth stages studied. The target theory was used to model the dose-survival relationship. Each growth stage studied was characterized by a distinct dose-response curve. Insects were killed by overheating and the lethal medium temperature for both species was estimated at 80 °C for the most resilient growth stage. Intermittent exposures at 1 or 5 min intervals were generally more effective in killing insects of both species than continuous irradiation. The fraction that survived increased as the moisture content of the medium increased from 6 or 9 to 12\%. The insects in the mobile state were observed to move towards the surface from inside the nutrient medium during irradiation. They also curled up and in some cases aggregation was observed. The authors did not detect any generation of ‘hot spots’ in the medium despite the concern of scientists involved in industrial heating of materials by microwaves.},
  keywords = {microwaves,mortality,target theory},
  file = {C\:\\Users\\dank\\Zotero\\storage\\BGWLCY6W\\Shayesteh and Barthakur - 1996 - Mortality and behaviour of two stored-product insect species during microwave irradiation.pdf;C\:\\Users\\dank\\Zotero\\storage\\KWCT8NY7\\S0022474X96000161.html}
}

@article{shelleyDroneRegistrationWill2019,
  title = {Drone {{Registration Will Not Prevent Another Gatwick}}},
  author = {Shelley, Andrew},
  date = {2019},
  journaltitle = {SSRN Electronic Journal},
  shortjournal = {SSRN Journal},
  issn = {1556-5068},
  doi = {10.2139/ssrn.3378277},
  url = {https://www.ssrn.com/abstract=3378277},
  urldate = {2025-03-06},
  abstract = {On 19-21 December 2018, at one of the busiest times of the year for air travel, one or more drones flew over Gatwick Airport and its runways, causing the airport to be closed for almost 33 hours, resulting in the cancellation of approximately 800 flights, and disrupting travel for approximately 120,000 people. In the wake of this incident there were calls from pilot associations and air traffic control for the registration of all drones, and implicit within those calls was the assumption that registration would have enabled Police in the United Kingdom to identify the operator(s) of the Gatwick drone(s). This paper reviews the existing regulation of drones in New Zealand and the United States, including the provisions for drone registration implemented in the United States. The paper then reviews the available technologies that could be used for remote identification as part of a drone registration scheme. I conclude that, given available technology, a registration scheme would not have prevented the incident at Gatwick and will not prevent similar incidents in future. The Gatwick incident was clearly malicious and intentional, and an individual that has such intent can readily circumvent any existing remote identification technology.},
  langid = {english},
  file = {C:\Users\dank\Zotero\storage\YQC86JHG\Shelley - 2019 - Drone Registration Will Not Prevent Another Gatwick.pdf}
}

