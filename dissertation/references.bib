  shorttitle = {Automatic, Rapid Screening of Seed Resistance in Cowpea, {{{\mkbibemph{Vigna}}}}{\mkbibemph{ Unguiculata}} ({{L}}.) {{Walpers}}, to the Seed Beetle {{{\mkbibemph{Callosobruchus}}}}{\mkbibemph{ Maculatus}} ({{F}}.) ({{Coleoptera}}},
  author = {Devereau, A. D. and Gudrups, I. and Appleby, J. H. and Credland, P. F.},
  date = {2003-01-01},
  journaltitle = {Journal of Stored Products Research},
  shortjournal = {Journal of Stored Products Research},
  volume = {39},
  number = {1},
