@article{renugadeviLeveragingAcousticInfrared2026,
  title = {Leveraging Acoustic and Infrared Feature Detection Systems to Manage Insect Pests in Storage Facilities},
  author = {Renugadevi, N. and Nivedhan, Karthik and Kartheek, VLN Cherukuri and Sivakumaran, N.},
  date = {2026-03-01},
  journaltitle = {Journal of Stored Products Research},
