  url = {https://www.sciencedirect.com/science/article/pii/S0167865524000394},
  urldate = {2025-11-22},
  abstract = {Sensor networks collect data that is often contaminated by noise. Therefore, it is often necessary to analyze sensor data to determine if a signal is present. This research project utilizes a machine learning algorithm that is able to detect a signal in the presence of noise. The algorithm incorporates the long short-term memory (LSTM) method to determine the presence or absence of a signal in the midst of white Gaussian noise. This machine learning approach was tested with computer generated data and has an accuracy of at least 98 \% for signal-to-noise levels greater than −12 dB (i.e., the signal power is 16 times smaller than the noise power). Furthermore, this algorithm can detect signals at least 65 \% accurately for signal-to-noise levels greater than approximately −26 dB (i.e., the signal power is 400 times smaller than the noise power). Moreover, only large anomalies in the data impact detection accuracy, but anomaly detection code eliminates this effect. This detection method is very robust and has ability to detect signals that are orders of magnitude smaller than noise levels. As a result, this machine learning algorithm has applications in surveillance and remote sensing.},
  keywords = {Anomaly,artificial intelligence,Long short-term memory,Low signal-to-noise,Neural network,Signal detection,Surveillance}
}

