@article{kalirameshDetectionInfestationCallosobruchus2013,
  title = {Detection of Infestation by {{{\mkbibemph{Callosobruchus}}}}{\mkbibemph{ Maculatus}} in Mung Bean Using Near-Infrared Hyperspectral Imaging},
