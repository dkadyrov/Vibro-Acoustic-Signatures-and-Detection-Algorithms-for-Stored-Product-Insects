@article{changBioacousticDetectionFour2025,
  title = {Bioacoustic Detection of Four {{{\mkbibemph{Bruchid}}}} Species in Bulk Red and Green Bulk-Stored Beans},
  author = {Chang, Feifei and Yang, Xiaojun and Li, Yang and Chen, Yunfang and Lu, Yujie and Zheng, Sizhu},
  date = {2025-05-01},
  journaltitle = {Journal of Stored Products Research},
