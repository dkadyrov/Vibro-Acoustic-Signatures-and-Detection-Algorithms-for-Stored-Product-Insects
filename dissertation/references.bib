@article{reimerCompactMicrowaveDevice2018,
  title = {A Compact Microwave Device for Monitoring Insect Activity in Grain Samples},
  author = {Reimer, Alex and Wiebe, Kelsey and Rao, Jinwei and Yao, Bimu and Gui, Yongsheng and Jian, Fuji and Fields, Paul and Jayas, Digvir S. and Hu, Can-Ming},
