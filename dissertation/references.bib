@article{munoz-seijasCharacterizationAllLife2024,
  title = {Characterization of All Life Stages of {{Tenebrio}} Molitor: {{Envisioning}} Innovative Applications for This Edible Insect},
  shorttitle = {Characterization of All Life Stages of {{Tenebrio}} Molitor},
  author = {Muñoz-Seijas, Nuno and Fernandes, Helena and López-Periago, José Eugenio and Outeiriño, David and Morán-Aguilar, María Guadalupe and Domínguez, José Manuel and Salgado, José Manuel},
  date = {2024-12-01},
  journaltitle = {Future Foods},
