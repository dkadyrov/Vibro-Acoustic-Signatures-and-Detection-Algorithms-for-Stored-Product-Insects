  doi = {10.1016/j.jspr.2026.102961},
  url = {https://www.sciencedirect.com/science/article/pii/S0022474X26000147},
  urldate = {2026-03-29},
  abstract = {Agricultural productivity is suffering a significant loss due to damage made by the insect infestations and pest activity. Farmers are heavily relying on pesticides to mitigate these pests and safeguard their crops. However, excessive use of pesticides poses not only environmental hazards but also risks to human health. This paper conducts a comprehensive survey of existing pest management techniques, focusing on the application of acoustic sensor technology. By assessing various acoustic sensors and the currently available pest-repelling systems, this paper proposes a theoretical pest detection and management system for controlling pest infestations in storage facilities. In future, this work motivates the implementation and rigorous testing of this system to evaluate its effectiveness in practical settings. This effort aims to advance agricultural pest management strategies in rural areas of India, leveraging innovative technologies to ensure sustainable and effective solutions.},
  keywords = {Acoustic sensors,Artificial neural network,Machine learning,Pest detection,Pest management},
