@article{wildExploringCivilDrone2016,
  title = {Exploring {{Civil Drone Accidents}} and {{Incidents}} to {{Help Prevent Potential Air Disasters}}},
  author = {Wild, Graham and Murray, John and Baxter, Glenn},
  date = {2016-09},
  journaltitle = {Aerospace},
  volume = {3},
  number = {3},
  pages = {22},
