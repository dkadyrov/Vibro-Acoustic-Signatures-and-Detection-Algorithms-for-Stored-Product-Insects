@article{auCalibrationMicrophonesAccordance2017,
  title = {Calibration of Microphones in Accordance with the {{International Standard IEC}} 61094-5:2016},
  shorttitle = {Calibration of Microphones in Accordance with the {{International Standard IEC}} 61094-5},
  author = {Au, Andrew C. H. and Lam, Brenda H.S. and Chau, Y. C.},
  date = {2017-12-07},
  journaltitle = {INTER-NOISE and NOISE-CON Congress and Conference Proceedings},
  shortjournal = {INTER-NOISE and NOISE-CON Congress and Conference Proceedings},
  volume = {255},
  number = {6},
  pages = {1022--1028},
  abstract = {The Standards and Calibration Laboratory (SCL) has developed a system for the calibration of working grade microphones with Constant Current Line Drive (CCLD) preamplifiers in accordance with the International Standard IEC 61094-5:2016. Unlike the traditional polarisation voltage supported preamplifier, the CCLD preamplifier gives output signals in the form of voltage modulation in the constant current power supply line. It is commonly used in multichannel acoustic measurements such as workplace noise assessments and anechoic chamber validations. Other proprietary names for the similar principle are Integrated Electronics Piezo Electric (IEPE) or Integrated Circuit Piezoelectric (ICP). Uniformity of sound pressure over the diaphragm of a microphone is crucial in the calibration of the pressure sensitivity of a microphone. It can be optimized by maintaining the radial symmetry of the sound field around the circumferences of the microphones. Non-uniformity of the sound pressure would contribute significantly in the measurement uncertainty at high frequencies. A tailor-made adaptor ring is used to replace the protection grid of the test microphone giving the configuration of a Laboratory Standard Microphone of Mechanical Configuration 2 (LS2) for the purpose of optimizing the uniformity of sound pressure over the diaphragm and provide similar acoustic impedances and frequency response characteristics to the test and reference microphones. Under this circumstance, the requirement for uniformity of the sound field reduces to a requirement of rotational symmetry of the sound field. The calibration system developed includes high precision reference multimeters, a function generator, a comparison coupler and band-pass filters. The pressure sensitivity of microphones with CCLD preamplifiers can be calibrated by comparison with the laboratory's standards. The calibration range for pressure field open-circuit sensitivity is from 63 Hz to 12.5 kHz and the best measurement uncertainty is 0.07 dB. Details of the proposed system and the uncertainty evaluation will be described in the paper.}
}

@article{aulickyTrappingInternalExternal2016,
  title = {Trapping of {{Internal}} and {{External Feeding Stored Grain Beetle Pests}} with {{Two Types}} of {{Pitfall Traps}}: A {{Two-year Field Study}}.},
  shorttitle = {Trapping of {{Internal}} and {{External Feeding Stored Grain Beetle Pests}} with {{Two Types}} of {{Pitfall Traps}}},
  author = {Aulicky, Radek and Stejskal, Vaclav and Kucerova, Zuzana and Trematerra, Pascale},
  date = {2016-01-01},
  journaltitle = {Plant Protection Science},
  volume = {52},
  number = {1},
  pages = {45},
  issn = {1212-2580},
  doi = {10.17221/30/2015-PPS},
  url = {https://openurl.ebsco.com/contentitem/doi:10.17221%2F30%2F2015-PPS?sid=ebsco:plink:crawler&id=ebsco:doi:10.17221%2F30%2F2015-PPS},
  urldate = {2025-11-04},
  abstract = {Discover this 2016 paper in Plant Protection Science by AULICKY, RADEK; STEJSKAL, VACLAV; KUCEROVA, ZUZANA; et. al. focusing on: BEETLES; PESTS; FIELD crops; FOOD crops; WHEAT germ Abstract: Pitfall trapping studies are available for particular stored grain pest species. In small farms, the stored grain pest control strategy is rarely species-specific but is often "pest ecological-group-specific" instead. A two-year field study was conducted in flat grain stores to compare the efficacy of cone-surface (PC trap; AgriSense-BCS Ltd., Pontypridd, UK) and probe-subsurface (WB Probe II Trap; Trécé Inc., Adair, USA) traps for three ecological insect pest groups (Group I, internal feeding primary pests; Group II, external feeding primary pests; Group III, external feeding secondary pests). Altogether, 1328 specimens (32\% Group I, 11\% Group II, and 57\% Group III) in 12 species of Coleoptera (17\% Group I, 25\% Group II, and 58\% Group III) were trapped. No significant differences were found in the efficacy of PC traps and WB Probe II Traps to catch the evaluated ecological pest groups over the long term. Our study indicated that for trends to appear in long-term trapping there was no need for the simultaneous use of both traps due to the low trapping differences between the surface and subsurface types of traps in all ecological pest groups. However, significant differences between the traps were found in the short-term evaluations and before and after fumigation; in that case, the use of both traps is recommended because of the higher sensitivity and more precise evaluation of efficacy of the control treatment effects.},
  langid = {english},
  file = {C:\Users\dank\Zotero\storage\CYC2ZBLW\Aulicky et al. - 2016 - Trapping of Internal and External Feeding Stored Grain Beetle Pests with Two Types of Pitfall Traps.pdf}
}

