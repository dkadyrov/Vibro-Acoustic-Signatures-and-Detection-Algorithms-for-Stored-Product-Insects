  date = {2026},
  journaltitle = {Pest Management Science},
  volume = {82},
  number = {1},
  pages = {42--53},
  issn = {1526-4998},
  doi = {10.1002/ps.70258},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/ps.70258},
  urldate = {2026-02-20},
  abstract = {According to statistics, global food losses due to pest damage amount to about 10–30\% of total production. Pest damage not only leads to a reduction in food quantity but also results in a decline in nutritional value. Traditional pest detection methods are plagued by delays and other shortcomings, making rapid detection a crucial component of grain pest control efforts. Accurate detection of the extent of pest damage enables timely implementation of control measures, significantly reducing food losses. Lure-and-capture techniques serve as important auxiliary tools for rapid pest detection. This study analyzed light, color, and pheromone lure-and-capture methods for storage pests. Additionally, it explored the effectiveness and limitations of X-ray imaging, acoustic transmission, machine vision, spectroscopy, electrical conductivity, and volatile organic compounds (VOCs) in rapid detection of grain pests. Furthermore, the study extensively analyzed the hardware and software systems associated with the latest rapid detection technologies, systems which are quite essential for implementing rapid detection. The review provides theoretical support and practical references for future development of pest control devices and pest detection equipment related to grain pest management. These methodologies and implementation approaches can also be extended to other agricultural pest control fields. © 2025 Society of Chemical Industry.},
  langid = {english},
  keywords = {detection,early warning,monitoring,research progress,stored grain pests,trapping},
  file = {C\:\\Users\\dank\\Zotero\\storage\\HMJU3A99\\Gong et al. - 2026 - Technologies and systems for pest detection and monitoring in stored grain.pdf;C\:\\Users\\dank\\Zotero\\storage\\B6ZAUG9E\\ps.html}
}

