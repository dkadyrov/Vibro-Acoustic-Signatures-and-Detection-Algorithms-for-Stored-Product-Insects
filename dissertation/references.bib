@article{dumbgenBlindBatAudible2023,
  title = {Blind as a {{Bat}}: {{Audible Echolocation}} on {{Small Robots}}},
  shorttitle = {Blind as a {{Bat}}},
  author = {Dümbgen, Frederike and Hoffet, Adrien and Kolundžija, Mihailo and Scholefield, Adam and Vetterli, Martin},
  date = {2023-03},
  journaltitle = {IEEE Robotics and Automation Letters},
