\PYG{n}{materials} \PYG{o}{=} \PYG{n}{db}\PYG{o}{.}\PYG{n}{Material}\PYG{o}{.}\PYG{n}{query}\PYG{o}{.}\PYG{n}{all}\PYG{p}{()} \PYG{c+c1}{\PYGZsh{}[Material \PYGZlt{}id\PYGZgt{}, ...]}

\PYG{c+c1}{\PYGZsh{} Retrieve all events for a specific insect species}
