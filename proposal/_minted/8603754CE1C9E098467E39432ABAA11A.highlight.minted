\PYG{n}{events} \PYG{o}{=} \PYG{n}{db}\PYG{o}{.}\PYG{n}{session}\PYG{o}{.}\PYG{n}{query}\PYG{p}{(}\PYG{n}{spidb}\PYG{o}{.}\PYG{n}{Event}\PYG{p}{)}
