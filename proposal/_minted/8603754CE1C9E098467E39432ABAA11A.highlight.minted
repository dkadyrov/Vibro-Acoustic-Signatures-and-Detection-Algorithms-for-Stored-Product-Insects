			\PYG{o}{.}\PYG{n}{filter}\PYG{p}{(}\PYG{n}{spidb}\PYG{o}{.}\PYG{n}{Event}\PYG{o}{.}\PYG{n}{material}\PYG{o}{.}\PYG{n}{id}\PYG{o}{.}\PYG{n}{in\PYGZus{}}\PYG{p}{([}\PYG{n}{m}\PYG{o}{.}\PYG{n}{id} \PYG{k}{for} \PYG{n}{m} \PYG{o+ow}{in} \PYG{n}{materials}\PYG{p}{]))}
