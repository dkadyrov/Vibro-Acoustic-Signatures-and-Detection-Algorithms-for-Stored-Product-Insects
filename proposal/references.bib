@article{decesarisExtractionEnvelopeImpulse2015,
  title = {Extraction of the Envelope from Impulse Responses Using Pre-Processed Energy Detection for Early Decay Estimation},
  author = {De Cesaris, Simona and D'Orazio, Dario and Morandi, Federica and Garai, Massimo},
  year = {2015},
  month = oct,
  journal = {The Journal of the Acoustical Society of America},
