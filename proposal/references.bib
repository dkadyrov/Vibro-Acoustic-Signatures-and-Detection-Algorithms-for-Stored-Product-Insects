@incollection{awikaMajorCerealGrains2011,
  title = {Major {{Cereal Grains Production}} and {{Use Around}} the {{World}}},
  booktitle = {Advances in {{Cereal Science}}: {{Implications}} to {{Food Processing}} and {{Health Promotion}}},
