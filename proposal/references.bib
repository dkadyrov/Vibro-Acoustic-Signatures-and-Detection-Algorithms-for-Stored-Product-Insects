@article{sutinAutomatedAcousticDetection2019,
  title = {Towards an {{Automated Acoustic Detection Algorithm}} for {{Wood-Boring Beetle Larvae}} ({{Coleoptera}}: {{Cerambycidae}} and {{Buprestidae}})},
