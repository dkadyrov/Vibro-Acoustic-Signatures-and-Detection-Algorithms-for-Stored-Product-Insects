@article{gogiToxicityRepellencePlant2016,
  title = {Toxicity and {{Repellence}} of {{Plant Oils Against Tribolium Castaneum}} (Herbst), {{Rhyzopertha Dominica}} (f.) and {{Trogoderma Granarium}} (e.)},
