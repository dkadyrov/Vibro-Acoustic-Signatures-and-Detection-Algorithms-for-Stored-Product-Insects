@article{zengUAVDataDatasetUnmanned2021,
  title = {{{UAVData}}: {{A}} Dataset for Unmanned Aerial Vehicle Detection},
  shorttitle = {{{UAVData}}},
  author = {Zeng, Yuni and Duan, Qianwen and Chen, Xiangru and Peng, Dezhong and Mao, Yao and Yang, Ke},
  year = {2021},
  month = apr,
