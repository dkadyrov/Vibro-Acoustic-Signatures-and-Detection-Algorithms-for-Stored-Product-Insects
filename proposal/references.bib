  volume = {103},
  number = {4},
  pages = {1135--1143},
  issn = {00220493, 00220493},
  doi = {10.1603/EC09214},
  urldate = {2024-10-27},
  abstract = {Adult and larval Oryctes rhinoceros (L.) (Coleoptera: Scarabaeidae: Dynastinae) were acoustically detected in live and dead palm trees and logs in recently invaded areas of Guam, along with Nasutitermes luzonicus Oshima (Isoptera: Termitidae), and other small, sound-producing invertebrates and invertebrates. The low-frequency, long-duration sound-impulse trains produced by large, active O. rhinoceros and the higher frequency, shorter impulse trains produced by feeding N. luzonicus had distinctive spectral and temporal patterns that facilitated their identi{\TH}cation and discrimination from background noise, as well as from roaches, earwigs, and other small sound-producing organisms present in the trees and logs The distinctiveness of the O. rhinoceros sounds enables current usage of acoustic detection as a tactic in Guam{\~O}s ongoing O. rhinoceros eradication program.},
  langid = {english},
  file = {C:\Users\dank\Zotero\storage\56SY3IA9\Mankin and Moore - 2010 - Acoustic Detection of Oryctes rhinoceros (Coleoptera Scarabaeidae Dynastinae) and Nasuti.pdf}
